# Supabase (필수 — Vercel Production에도 동일하게 설정)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Supabase Dashboard anon key (publishable key와 동일 값 가능)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_PROJECT_REF=your-project-ref

# 배포 사이트 URL (setup:google 스크립트에서 Redirect URL 등록에 사용)
NEXT_PUBLIC_SITE_URL=https://thai-korea-community.vercel.app

# Google OAuth — Supabase Dashboard에 등록 (npm run setup:google)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Supabase Dashboard → Account → Access Tokens
# SUPABASE_ACCESS_TOKEN=

# Kakao Maps (주소 검색·지도)
NEXT_PUBLIC_KAKAO_MAP_KEY=
KAKAO_REST_API_KEY=

# 프리미엄 결제 — 테스트 단계에서는 mock 권장
PREMIUM_PAYMENT_MOCK=true
NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=
TOSS_PAYMENTS_SECRET_KEY=

# 운영자 계정 (선택, 기본값 있음)
NEXT_PUBLIC_OPERATOR_CODE=
NEXT_PUBLIC_OPERATOR_NAME=
NEXT_PUBLIC_OPERATOR_NICKNAME=
NEXT_PUBLIC_OPERATOR_GMAIL=
NEXT_PUBLIC_OPERATOR_PHONE=
NEXT_PUBLIC_OPERATOR_PASSWORD=
